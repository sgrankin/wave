{
  "name": "wave-web",
  "private": true,
  "type": "module",
  "description": "Browser client for the Wave Go server: a TypeScript port of the optimistic client (OptimisticClient + clientcc + OT) over WebSocket, plus the Lit editor.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test src/wave/*.test.ts src/editor/*.test.ts",
    "build": "node esbuild.mjs",
    "test:web": "node testing/web-runner.mjs",
    "test:browser": "node --test test/*.browser.test.ts",
    "test:integration": "node --test test/integration.test.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.2",
    "playwright": "^1.60.0",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "lit": "^3.2.1"
  }
}
